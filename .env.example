# puya CLI — env vars (copiar a tu config local y completar).
# Ver README "Setup local" para dónde ponerlo según tu OS.

# Backend del proxy (no se cambia salvo que muevas puya-chat de host).
PUYA_BASE_URL=https://puya-chat-interno.vercel.app

# API keys — una por entorno. Materializalas (una sola vez) en:
#   https://puya-chat-interno.vercel.app/cli-account
# Cada key encapsula su target_env, cli_mode (read_only | full),
# modelos permitidos y rate limit. Todo eso vive server-side.

PUYA_API_KEY_STAGING=puya_...
PUYA_API_KEY_PROD=puya_...

# Default cuando no pasás --env. Obligatorio si tenés ambas keys cargadas
# (sin esto el CLI rehúsa operar para no adivinar). Si cargás solo una,
# se infiere y podés omitir esta variable.
PUYA_TARGET_ENV=staging
