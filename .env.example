# puya CLI — env vars de ejemplo. Copiar a `.env` y completar.
# Ver README "Configuración" para detalle.

# ─────────────────────────────────────────────────────────────
# Odoo — multi-entorno (recomendado)
# ─────────────────────────────────────────────────────────────
ODOO_ENV=staging                                    # production | staging

ODOO_STAGING_URL=https://cmcorpcl-puyacentro-XXXX.dev.odoo.com
ODOO_STAGING_DB=cmcorpcl-puyacentro-XXXX
ODOO_STAGING_API_KEY=...

ODOO_PRODUCTION_URL=https://...
ODOO_PRODUCTION_DB=...
ODOO_PRODUCTION_API_KEY=...

# Login: si es el mismo en ambos entornos, sumalo solo acá.
# Si difiere, usá ODOO_STAGING_LOGIN y ODOO_PRODUCTION_LOGIN.
ODOO_LOGIN=tu_email@costasurmat.cl

# ─────────────────────────────────────────────────────────────
# Role efectivo
# ─────────────────────────────────────────────────────────────
PUYA_ROLE=vendedor                                  # vendedor | administrativo | developer

# ─────────────────────────────────────────────────────────────
# Supabase (audit + pending actions)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://lozdcwaeynloidrkeqfn.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...

# ─────────────────────────────────────────────────────────────
# Notificaciones de aprobación
# ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APPROVAL_CHANNEL=C0...

# Alternativa (fallback si Slack no está configurado)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
